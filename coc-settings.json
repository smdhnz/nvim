{
  "prettier.enable": true,
  "files.associations": {
    "*.vue": "vue"
  },
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "typescript",
    "json",
    "yaml",
    "vue"
  ],
  "diagnostic.floatConfig": {
    "border": true,
    "rounded": true
  },
  "hover.floatConfig": {
    "border": true,
    "rounded": true
  }
}
